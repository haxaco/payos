{
  "name": "@sly/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "pnpm --filter '@sly/types' --filter '@sly/utils' --filter '@sly/cards' --filter '@sly_ai/sdk' --filter '@sly_ai/mcp-server' run build && tsup src/index.ts src/worker.ts --format esm --target node20",
    "vercel-build": "pnpm --filter '@sly/types' --filter '@sly/utils' --filter '@sly/cards' --filter '@sly_ai/sdk' --filter '@sly_ai/mcp-server' run build && tsup src/index.ts --format esm --target node20",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "INTEGRATION=true vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "seed:db": "tsx scripts/seed-database.ts",
    "seed:all": "tsx scripts/seed-all.ts",
    "seed:streams": "tsx scripts/seed-streams.ts",
    "seed:agents": "tsx scripts/seed-agent-activity.ts",
    "seed:enhance": "tsx scripts/enhance-seed-data.ts",
    "seed:comprehensive": "tsx scripts/seed-enhanced-comprehensive.ts",
    "seed:power-user": "tsx scripts/seed-power-user.ts",
    "seed:ucp": "tsx scripts/seed-ucp-data.ts",
    "seed:demo": "tsx scripts/seed-demo-scenarios.ts",
    "update:corridor-ids": "tsx scripts/update-transfers-corridor-id.ts",
    "check:rls": "tsx scripts/check-rls-in-migrations.ts",
    "cleanup:simulations": "tsx scripts/cleanup-simulations.ts",
    "demo:agent-checkout": "tsx scripts/demo-agent-checkout.ts",
    "seed:zindigi": "tsx scripts/seed-zindigi-demo.ts",
    "mock:moltbook": "tsx scripts/mock-moltbook-agent.ts",
    "generate:openapi": "tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@coinbase/coinbase-sdk": "^0.25.0",
    "@coinbase/x402": "^2.1.0",
    "@hono/zod-openapi": "^0.18.0",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "@sly/api-client": "workspace:*",
    "@sly/cards": "workspace:*",
    "@sly/types": "workspace:*",
    "@sly/utils": "workspace:*",
    "@sly_ai/mcp-server": "workspace:*",
    "@sly_ai/sdk": "workspace:*",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.47.10",
    "ajv": "^8.17.1",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "hono": "^4.6.14",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "mppx": "^0.4.12",
    "resend": "^4.1.0",
    "stripe": "^20.2.0",
    "undici": "^7.0.0",
    "viem": "^2.47.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@hono/node-server": "^1.19.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.15",
    "supertest": "^7.1.4",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.15"
  }
}
