# PayOS API Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED: Supabase Configuration
# ===========================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ===========================================
# REQUIRED: Application Settings
# ===========================================
NODE_ENV=development
PORT=4000
PAYOS_ENVIRONMENT=sandbox

# ===========================================
# OPTIONAL: CORS Settings
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# OPTIONAL: Circle Integration
# ===========================================
CIRCLE_API_KEY=your_circle_api_key_here

# ===========================================
# OPTIONAL: Stripe Integration
# ===========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===========================================
# OPTIONAL: Coinbase CDP Integration
# ===========================================
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_PRIVATE_KEY=your_cdp_private_key

# ===========================================
# OPTIONAL: One-Click Publish to agentic.market (CDP Bazaar)
# ===========================================
# CDP credentials used by the Sly publish flow to route verify+settle for
# published x402 endpoints through the CDP Facilitator (which auto-indexes
# the listing on agentic.market on first successful settle).
CDP_API_KEY_SECRET=your_cdp_api_key_secret
CDP_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# Sly-managed probe wallet — triggers the synthetic first-settle on publish
# so the dashboard shows "processing" immediately instead of waiting for
# an organic buyer.
SLY_PUBLISH_PROBE_WALLET_ID=
SLY_PUBLISH_PROBE_BUDGET_USDC=10

# Catalog poller — confirms agentic.market indexing of newly published endpoints.
X402_PUBLISH_POLLER_INTERVAL_MS=60000
X402_PUBLISH_INDEX_SLA_MINUTES=30
MOCK_X402_PUBLISH_POLLER=false
ENABLE_X402_PUBLISH_POLLER=true
AGENTIC_MARKET_API_URL=https://api.agentic.market/v1/services

# ===========================================
# OPTIONAL: EVM Wallet
# ===========================================
EVM_PRIVATE_KEY=your_evm_private_key_hex
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# ===========================================
# OPTIONAL: Compliance Provider
# ===========================================
COMPLIANCE_PROVIDER=mock

# ===========================================
# OPTIONAL: Platform Admin & Beta Access
# ===========================================
PLATFORM_ADMIN_API_KEY=generate-a-random-key-here
GOOGLE_CLIENT_ID=your_google_oauth_client_id
BETA_ADMIN_EMAIL=admin@yourdomain.com
PAYOS_FEATURE_CLOSED_BETA=true
