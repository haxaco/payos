# apps/marketplace-sim/.env — copy to .env and fill in
# This file is the template. Never commit real keys.

# Sly API endpoint and admin key (must match your running Sly API).
# REPLACE SLY_PLATFORM_ADMIN_KEY with the value your Sly API was started with
# (check apps/api/.env → PLATFORM_ADMIN_API_KEY). Never commit a real key.
SLY_API_URL=http://localhost:4000
SLY_PLATFORM_ADMIN_KEY=REPLACE_ME_WITH_PLATFORM_ADMIN_KEY

# Shared secret required on every sim-sidecar request (Authorization: Bearer ...).
# REQUIRED when SIM_HOST is anything other than 127.0.0.1. The server refuses
# to start on 0.0.0.0 without this set.
SIM_SHARED_SECRET=

# Bind host / port. Default binds to loopback for local safety; containers
# should set SIM_HOST=0.0.0.0 and SIM_SHARED_SECRET together.
SIM_HOST=127.0.0.1
SIM_PORT=4500

# Pin the tenant that seed-agent targets via the Sly API. Without this, the
# Sly API's seed-agent picks the first active tenant (non-deterministic). Set
# this to the tenant your dashboard user is logged into so sim agents appear.
SIM_TENANT_ID=

# OpenRouter API key for the default "openrouter" processor mode.
# Without this, only the "scripted" and "subagent" modes work.
OPENROUTER_API_KEY=

# Anthropic API key for the "api" processor mode (required only when --mode api)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Default model (haiku = cheap + fast, sonnet = higher quality)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Budget cap per run (USD). Run auto-stops when this is exceeded.
BUDGET_USD_CAP=5

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Supabase access for the markdown scenario template store.
# The sim sidecar reads/writes scenario_templates directly using the service role.
# These match the values you'd find in the Sly API's .env.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Separate budget cap for the LLM compile step (Phase B). Keeps a runaway
# compile from draining the per-round budget.
COMPILE_BUDGET_USD_CAP=2
